<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="NTScanGUI.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:NTScanGUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Grid Grid.Row="0"
              Padding="16,12,16,8"
              ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Back -->
            <Button x:Name="BackButton"
                    Grid.Column="0"
                    Width="36" Height="36"
                    Padding="0"
                    ToolTipService.ToolTip="Back"
                    Click="BackButton_Click"
                    IsEnabled="False">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <!-- Up -->
            <Button x:Name="UpButton"
                    Grid.Column="1"
                    Width="36" Height="36"
                    Padding="0"
                    ToolTipService.ToolTip="Up one level"
                    Click="UpButton_Click">
                <FontIcon Glyph="&#xE74A;" FontSize="14" />
            </Button>

            <!-- Refresh -->
            <Button x:Name="RefreshButton"
                    Grid.Column="2"
                    Width="36" Height="36"
                    Padding="0"
                    ToolTipService.ToolTip="Refresh"
                    Click="RefreshButton_Click">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>

            <!-- Address bar (click-to-edit) -->
            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0"
                    Height="36">
                <Grid>
                    <BreadcrumbBar x:Name="PathBreadcrumb"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   ItemClicked="PathBreadcrumb_ItemClicked"
                                   Tapped="AddressBar_Tapped" />

                    <TextBox x:Name="AddressTextBox"
                             Visibility="Collapsed"
                             VerticalAlignment="Stretch"
                             BorderThickness="0"
                             CornerRadius="6"
                             KeyDown="AddressTextBox_KeyDown"
                             LostFocus="AddressTextBox_LostFocus" />
                </Grid>
            </Border>

            <!-- Browse folder picker -->
            <Button Grid.Column="4"
                    Width="36" Height="36"
                    Padding="0"
                    ToolTipService.ToolTip="Browse…"
                    Click="BrowseTargetPath_Click">
                <FontIcon Glyph="&#xED25;" FontSize="14" />
            </Button>
        </Grid>

        <!-- ═══ Info bar ═══ -->
        <Grid Grid.Row="1"
              Padding="16,0,16,4"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="0"
                       Text="Navigate to a folder."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <Button x:Name="FindDuplicatesButton"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="FindDuplicates_Click"
                    Content="Find Duplicates"
                    FontSize="12"
                    Padding="10,5" />

            <DropDownButton Grid.Column="2"
                            VerticalAlignment="Center"
                            Content="Options"
                            FontSize="12"
                            Padding="10,5">
                <DropDownButton.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <ToggleMenuFlyoutItem x:Name="AccurateModeToggle"
                                              Text="Accurate mode (ADS + allocation)" />
                        <ToggleMenuFlyoutItem x:Name="FollowSymlinksToggle"
                                              Text="Follow symlinks" />
                        <ToggleMenuFlyoutItem x:Name="ShowFilesToggle"
                                              Text="Include individual files" />
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </Grid>

        <!-- ═══ Progress bar ═══ -->
        <ProgressBar x:Name="ScanProgressBar"
                     Grid.Row="2"
                     IsIndeterminate="True"
                     Visibility="Collapsed"
                     Margin="0,0,0,0" />

        <!-- ═══ Column headers ═══ -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,1"
                Padding="16,6,16,6">
            <Grid ColumnSpacing="8"
                  ColumnDefinitions="28,*,80,110,110,90">
                <TextBlock Grid.Column="0" />
                <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="12" Text="Name" />
                <TextBlock Grid.Column="2" FontWeight="SemiBold" FontSize="12" Text="Kind" />
                <TextBlock Grid.Column="3" FontWeight="SemiBold" FontSize="12" Text="Size" />
                <TextBlock Grid.Column="4" FontWeight="SemiBold" FontSize="12" Text="Allocated" />
                <TextBlock Grid.Column="5" FontWeight="SemiBold" FontSize="12" Text="Modified" />
            </Grid>
        </Border>

        <!-- ═══ Directory listing ═══ -->
        <ListView x:Name="EntriesListView"
                  Grid.Row="4"
                  IsItemClickEnabled="True"
                  ItemClick="EntriesListView_ItemClick"
                  SelectionMode="Single"
                  Padding="0,0,0,16">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ScanEntryRow">
                    <Grid Padding="4,5,4,5"
                          ColumnSpacing="8"
                          ColumnDefinitions="28,*,80,110,110,90">
                        <FontIcon Grid.Column="0"
                                  Glyph="{x:Bind IconGlyph}"
                                  FontSize="16"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Name}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Kind}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind LogicalSize}"
                                   FontSize="12" />
                        <TextBlock Grid.Column="4"
                                   Text="{x:Bind AllocatedSize}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                        <TextBlock Grid.Column="5"
                                   Text="{x:Bind Modified}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
